#define SEN_COLOR IN_4
#define M_EMPUJE  OUT_B  // Motor con tornillo sin fin
#define M_TIJERA  OUT_AC // Motores de elevación

// --- PARÁMETROS DE MOVIMIENTO PARA TORNILLO SIN FIN ---
// Ajustar estos valores según el largo físico de tu tornillo
#define VEL_GOLPE    80   // //ajustar velocidad
#define ANG_GOLPE    1400 // //ajustar rotación o parámetros de giro

int color_detectado = 0;
bool disparar_barra = false;

// Tarea 1: Control físico del Empuje (Ida y Vuelta)
task task_mecanismo_empuje() {
    while(true) {
        if (disparar_barra) {

            // 1. Movimiento hacia ADENTRO (Cerrar/Empujar)
            // //ajustar parámetros de giro
            RotateMotor(M_EMPUJE, VEL_GOLPE, -ANG_GOLPE);

            Wait(250); // Pausa para asegurar el impacto

            // 2. Movimiento hacia AFUERA (Regresar a posición original)
            // Cambiamos a signo POSITIVO para que el motor invierta el giro
            // //ajustar parámetros de giro
            RotateMotor(M_EMPUJE, VEL_GOLPE, ANG_GOLPE);

            disparar_barra = false;
        }
        Wait(50);
    }
}

// Tarea 2: Monitoreo constante del sensor de color
task task_sensor_color() {
    SetSensorColorFull(SEN_COLOR);
    while(true) {
        color_detectado = Sensor(SEN_COLOR);

        // Debug visual en pantalla
        if(color_detectado == 1) {
            TextOut(0, LCD_LINE3, "AIRE / NEGRO   ", true);
        } else {
            NumOut(0, LCD_LINE3, "COLOR: ", true);
            NumOut(40, LCD_LINE3, color_detectado);
        }
        Wait(50);
    }
}

// Tarea 3: Lógica de decisión principal
task main() {
    StartTask(task_sensor_color);
    StartTask(task_mecanismo_empuje);

    TextOut(0, LCD_LINE1, "SISTEMA LISTO");

    while(true) {

        /* //robot_detenido
        // Esta sección se activará cuando integres la seńal del Maestro.
        // El bloque esperará a que el robot esté en pausa total.

        if (robot_detenido == true) {
        */

            // 1. Trigger: Esperamos un momento a que la pelota se detenga frente al brazo
            Wait(800);

            // 2. Verificación de color:
            // Filtramos aire(1), vacío(0) y verde(3).
            if (color_detectado > 1 && color_detectado != 3) {

                PlaySound(SOUND_UP);

                // 3. Activamos el flag para que task_mecanismo_empuje inicie
                disparar_barra = true;

                // Esperamos a que la barra termine su ciclo de ida y vuelta
                while(disparar_barra) { Wait(10); }

                // Pausa de seguridad antes de buscar la siguiente pelota
                Wait(3000);
            }

        /* } // Fin de sección //robot_detenido
        */

        Wait(50);
    }
}
