// -- Programa principal --------------------------------------------
task main()
{
    // Espera pulsaciÛn del botÛn naranja antes de arrancar
    until(ButtonPressed(BTNCENTER, false));
    Wait(500);

    // Elige quÈ versiÛn de cuadrado ejecutar:
    cuadrado_strafe();   // Cuadrado sin girar (omnidireccional puro)
    // cuadrado_giro();  // Cuadrado girando en esquinas

    PlayTone(880, 400);  // Pitido al terminar
}
