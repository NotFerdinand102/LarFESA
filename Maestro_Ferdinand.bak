// ================================================================
//  MAESTRO_BT_SALIDA.nxc
// ================================================================

#define ESCLAVO_SLOT 1
#define BUZON_TX     1
#define BUZON_RX     2

#define V            60   // Velocidad de salida un poco más alta
#define V_NORMAL     55
#define SOM          35
#define DIST         14

// Tiempo estimado para recorrer 40cm (Ajustar según potencia de batería)
// Si 40cm no son suficientes, aumenta este valor.
#define TIEMPO_SALIDA 2500

#define SEN_FRONT_IZQ IN_1
#define SEN_LAT_IZQ   IN_2
#define SEN_FRONT_DER IN_3
#define SEN_US        IN_4

#define M_LATERAL     OUT_A
#define M_IZQ         OUT_B
#define M_DER         OUT_C

void parar() { Off(OUT_ABC); Wait(200); }

void adelante(int vel) {
    OnRev(M_IZQ, vel);
    OnFwd(M_DER, vel);
    Off(M_LATERAL);
}

task main() {
    SetSensorLight(SEN_FRONT_IZQ);
    SetSensorLight(SEN_LAT_IZQ);
    SetSensorLight(SEN_FRONT_DER);
    SetSensorLowspeed(SEN_US);

    TextOut(0, LCD_LINE1, "MODO: SALIDA");

    // --- FASE 1: SALIDA DE CASILLA (IGNORAR SENSORES) ---
    // El robot avanza en línea recta ignorando el color negro
    adelante(V);
    Wait(TIEMPO_SALIDA);

    PlaySound(SOUND_DOUBLE_BEEP);
    TextOut(0, LCD_LINE1, "MODO: EXPLORAR");

    // --- FASE 2: BUCLE DE NAVEGACIÓN NORMAL ---
    while(true) {
        int fi = Sensor(SEN_FRONT_IZQ);
        int ti = Sensor(SEN_LAT_IZQ);
        int fd = Sensor(SEN_FRONT_DER);
        int ul = SensorUS(SEN_US);

        // 1. OBJETIVO ENCONTRADO
        if (fi < SOM && fd < SOM && ul < DIST) {
            parar();
            SendRemoteNumber(ESCLAVO_SLOT, BUZON_TX, 1);

            int respuesta = 0;
            // Espera hasta que el esclavo confirme (Bluetooth)
            until(ReceiveRemoteNumber(BUZON_RX, true, respuesta) == NO_ERR);

            if(respuesta == 1) {
                PlaySound(SOUND_UP);
                // Pequeńo retroceso tras recolectar
                OnFwd(M_IZQ, V_NORMAL); OnRev(M_DER, V_NORMAL); Wait(800); parar();
            }
        }

        // 2. FRONTERA (Evitar bordes negros)
        else if (fi < SOM || fd < SOM) {
            parar();
            OnFwd(M_IZQ, V_NORMAL); OnRev(M_DER, V_NORMAL); Wait(400); // Atrás
            // Movimiento lateral para buscar nueva ruta
            OnRev(M_LATERAL, V_NORMAL); OnFwd(M_IZQ, V_NORMAL/2); OnFwd(M_DER, V_NORMAL/2);
            Wait(500);
            parar();
        }

        // 3. SEGUIDOR LATERAL (Permanecer en Blanco)
        else {
            if (ti < SOM) { // Toca borde lateral, corregir a la derecha
                OnRev(M_LATERAL, V_NORMAL);
                OnRev(M_IZQ, V_NORMAL);
                OnFwd(M_DER, V_NORMAL);
            } else { // Busca borde hacia la izquierda
                OnFwd(M_LATERAL, V_NORMAL - 20);
                OnRev(M_IZQ, V_NORMAL);
                OnFwd(M_DER, V_NORMAL);
            }
        }
        Wait(20);
    }
}
